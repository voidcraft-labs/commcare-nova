# Run logger — saves LLM call logs for debugging/replay
RUN_LOGGER=1

# Anthropic API key (optional — only used by offline scripts like
# test-schema.ts and sync-knowledge.ts. The app itself is BYOAPI-key:
# users provide their key via the UI, stored in localStorage.)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Confluence knowledge sync (optional — only needed for scripts/sync-knowledge.ts)
# CONFLUENCE_BASE_URL=https://api.atlassian.com/ex/confluence/your-cloud-id/wiki
# CONFLUENCE_EMAIL=you@example.com
# CONFLUENCE_API_TOKEN=your-token-here
# RATE_LIMIT_MS=100
# TRIAGE_BATCH_SIZE=5
