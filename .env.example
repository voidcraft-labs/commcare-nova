# Run logger — saves LLM call logs for debugging/replay
RUN_LOGGER=1

# Knowledge sync scripts (optional — only needed for scripts/sync-knowledge.ts)
# The app itself uses a BYOAPI-key model — users provide their Anthropic key
# via the UI, stored in localStorage. This key is only for offline scripts.
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# CONFLUENCE_BASE_URL=https://api.atlassian.com/ex/confluence/your-cloud-id/wiki
# CONFLUENCE_EMAIL=you@example.com
# CONFLUENCE_API_TOKEN=your-token-here
# RATE_LIMIT_MS=100
# TRIAGE_BATCH_SIZE=5
