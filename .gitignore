# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/out/

# production
/build

# misc
.DS_Store
*.pem

# exclude any dir starting with dot (e.g. .idea, .vscode-workspace files dropped by editors),
# but keep the App Router's `.well-known` discovery routes — OAuth AS / OIDC /
# protected-resource metadata must be tracked in-repo because Next.js emits them
# from app/.well-known/*/route.ts at build time.
.*/
!.well-known/
!app/.well-known/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# generated knowledge-sync output
/scripts/knowledge/output/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
