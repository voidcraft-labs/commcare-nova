# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/out/

# production
/build

# misc
.DS_Store
*.pem

# Editor/IDE dot-directories at the repo root (.idea, .vscode-workspace, etc.)
# Anchored to the root so nested conventional dot-dirs like `app/.well-known/`
# work without special casing.
/.*/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# firebase emulator output (generated by `npm run test:integration`)
firebase-debug.log
firestore-debug.log
ui-debug.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# generated knowledge-sync output
/scripts/knowledge/output/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
