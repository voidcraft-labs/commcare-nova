# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/out/

# production
/build

# misc
.DS_Store
*.pem

# Editor/IDE dot-directories at the repo root (.idea, .vscode-workspace, etc.)
# Anchored to the root so nested conventional dot-dirs like `app/.well-known/`
# work without special casing.
/.*/
# ...except .github/ — that's project config (CI workflows, Dependabot), not
# editor cruft, so it must be tracked.
!/.github/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# firebase emulator output (generated by `npm run test:integration`)
firebase-debug.log
firestore-debug.log
ui-debug.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# generated knowledge-sync output
/scripts/knowledge/output/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin

# Playwright smoke suite (generated)
/e2e/.auth/
/e2e/test-results/
/e2e/playwright-report/
/e2e/multiplayer-screenshots/
/playwright/.cache/
/test-results/
/playwright-report/
