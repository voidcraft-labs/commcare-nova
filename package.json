		"happy-dom": "^20.10.6",
		"lefthook": "^2.1.10",
		"pg": "^8.22.0",
		"react-scan": "^0.5.3",
		"tailwindcss": "^4",
		"tsx": "^4.23.1",
		"typescript": "7.0.2",
		"vitest": "^4.1.10"
	},
	"overrides": {
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"postcss": "^8.5.12",
		"uuid": "^14.0.0"
	}
}
