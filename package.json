		"sharp": "^0.34.5",
		"tailwind-merge": "^3.6.0",
		"tiptap-markdown": "^0.9.0",
		"tw-animate-css": "^1.4.0",
		"use-stick-to-bottom": "^1.1.4",
		"uuid": "^14.0.0",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "^4.3.6",
