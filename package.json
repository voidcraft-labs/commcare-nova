{
	"name": "commcare-nova",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "npm run db:dev && next dev",
		"db:dev": "docker compose up -d --wait && atlas migrate apply --env testcontainer --url \"postgres://nova:nova@localhost:5432/nova_cases?sslmode=disable\" --allow-dirty",
		"db:dev:down": "docker compose down",
		"build": "next build",
		"start": "next start",
		"lint": "biome check --error-on-warnings",
		"format": "biome check --write",
		"typecheck": "fumadocs-mdx && tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:leaks": "vitest run --detect-async-leaks",
		"test:integration": "node_modules/.bin/firebase emulators:exec --only firestore --project demo-test 'GOOGLE_CLOUD_PROJECT=demo-test ./node_modules/.bin/vitest run --no-file-parallelism integration.test.ts'",
		"db:diff": "atlas migrate diff --env local",
		"db:lint": "atlas migrate lint --env local --latest 1"
	},
