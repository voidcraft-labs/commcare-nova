{
	"name": "commcare-nova",
	"version": "0.5.0",
	"private": true,
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.18.0",
			"onFail": "error"
		},
		"packageManager": {
			"name": "npm",
			"version": "12.0.1",
			"onFail": "error"
		}
	},
	"allowScripts": {
		"@sentry/cli": false,
		"cpu-features": false,
		"esbuild": false,
		"fsevents": false,
		"lefthook": false,
		"protobufjs": false,
		"sharp": false,
		"ssh2": false
	},
	"scripts": {
		"postinstall": "fumadocs-mdx",
		"predev": "node scripts/check-node.mjs",
		"dev": "npm run db:dev && NEXT_TELEMETRY_DISABLED=1 next dev",
		"db:dev": "docker compose up -d --wait && NOVA_DB_LOCAL_URL=postgres://nova:nova@localhost:5432/nova_cases?sslmode=disable npm run db:migrate",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:dev:down": "docker compose down",
		"build": "NEXT_TELEMETRY_DISABLED=1 next build && tsc --noEmit",
		"start": "next start",
		"lint": "biome check --error-on-warnings",
		"format": "biome check --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:changed": "vitest run --changed origin/main",
		"test:leaks": "vitest run --detect-async-leaks --pool=forks --testTimeout=30000",
		"test:smoke": "bash scripts/smoke.sh",
		"test:smoke:headed": "bash scripts/smoke.sh --headed",
		"test:smoke:url": "playwright test --project=public",
		"case:manual": "PORT=3100 SMOKE_BASE_URL=http://localhost:3100 BETTER_AUTH_URL=http://localhost:3100 CASE_WORKSPACE_MANUAL=1 bash scripts/smoke.sh --project=case-workspace-manual --headed",
		"mp:watch": "MP_TILE=1 MP_SLOWMO=${MP_SLOWMO:-3000} bash scripts/smoke.sh --project=multiplayer --headed",
		"mp:manual": "MP_MANUAL=1 bash scripts/smoke.sh --project=mp-manual --headed"
	},
	"dependencies": {
		"@ai-sdk/openai": "^4.0.16",
		"@ai-sdk/react": "4.0.34",
		"@ai-sdk/workflow": "1.0.31",
		"@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
		"@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^3.0.0",
		"@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
		"@better-auth/api-key": "1.6.23",
		"@better-auth/oauth-provider": "1.6.23",
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/language": "^6.12.4",
		"@floating-ui/react": "^0.27.20",
		"@google-cloud/cloud-sql-connector": "^1.11.2",
		"@google-cloud/kms": "^5.6.0",
		"@google-cloud/storage": "^7.19.0",
		"@googlemaps/js-api-loader": "^2.1.1",
		"@iconify/react": "^6.0.2",
		"@lezer/common": "^1.5.1",
		"@lezer/highlight": "^1.2.3",
		"@lezer/lr": "^1.4.8",
		"@modelcontextprotocol/sdk": "^1.26.0",
		"@radix-ui/react-dropdown-menu": "^2.1.20",
		"@radix-ui/react-popover": "^1.1.19",
		"@radix-ui/react-use-controllable-state": "^1.2.2",
		"@sentry/nextjs": "^10.65.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.14.6",
		"@tiptap/extension-image": "^3.27.3",
		"@tiptap/extension-list": "^3.27.3",
		"@tiptap/extension-mention": "^3.27.3",
		"@tiptap/extension-subscript": "^3.27.3",
		"@tiptap/extension-superscript": "^3.27.3",
		"@tiptap/extension-table": "^3.27.3",
		"@tiptap/extension-table-cell": "^3.27.3",
		"@tiptap/extension-table-header": "^3.27.3",
		"@tiptap/extension-table-row": "^3.27.3",
